# Ensure hook runs on the project's target Node version (18+ required by ESLint)
if [ -s "$HOME/.nvm/nvm.sh" ]; then
  export NVM_DIR="$HOME/.nvm"
  # shellcheck disable=SC1091
  . "$HOME/.nvm/nvm.sh"
  nvm use --silent 2>/dev/null || nvm use --silent 20 2>/dev/null || true
fi

npm run lint
npm run test
